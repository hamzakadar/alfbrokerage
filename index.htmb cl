<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="robots" content="noindex, nofollow">
<title>Pillars ALF Partners | Confidential Minnesota ALF Sales</title>
<meta name="description" content="Confidential sales for Minnesota assisted living facilities. Neutral brokers. Seller pays broker fee. Buyer pays nothing.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700;800&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg:        #141718;
  --bg2:       #1c1f21;
  --bg3:       #232729;
  --border:    #2e3336;
  --border-lt: #3a3f43;
  --white:     #ffffff;
  --off-white: #e8eaec;
  --muted:     #8c9198;
  --amber:     #2e6da4;
  --amber-lt:  #4a8fc0;
  --amber-dim: rgba(46,109,164,0.15);
  --red-dim:   rgba(180,40,40,0.12);
  --red-rule:  #b42828;
  --teal:      #1a8a7a;
  --teal-dim:  rgba(26,138,122,0.1);
  --teal-rule: #1a8a7a;
  --green:     #1a7a4a;
  --green-dim: rgba(26,122,74,0.12);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Barlow', sans-serif;
  background: var(--bg);
  color: var(--off-white);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* TYPE */
h1,h2,h3,h4 {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.02em;
  line-height: 1.05;
}
h1 { font-size: clamp(2.8rem, 6vw, 5rem); }
h2 { font-size: clamp(1.9rem, 4vw, 3rem); }
h3 { font-size: 1.25rem; }
p { color: var(--muted); line-height: 1.7; }
a { color: inherit; }

/* LAYOUT */
.wrap    { max-width: 1160px; margin: 0 auto; padding: 0 2rem; }
.wrap-sm { max-width: 780px;  margin: 0 auto; padding: 0 2rem; }
section  { padding: 5rem 2rem; }

/* LABEL */
.label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--amber);
  display: block;
  margin-bottom: 0.9rem;
}

/* RULE */
.h-rule { border: none; border-top: 1px solid var(--border); }



/* HEADER */
.site-header {
  position: sticky; top: 0; z-index: 300;
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  padding: 0 2rem;
}
.header-inner {
  max-width: 1160px; margin: 0 auto;
  display: flex; align-items: center; justify-content: space-between;
  height: 66px; gap: 1rem; flex-wrap: wrap;
}
.logo {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 1.35rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--white);
  text-decoration: none;
  line-height: 1.1;
}
.logo small {
  display: block;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  color: var(--muted);
  margin-top: 2px;
}
.nav-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: center; }

/* BUTTONS */
.btn {
  display: inline-block;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 1.1rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  text-decoration: none;
  cursor: pointer;
  border: none;
  border-radius: 0;
  transition: all 0.15s;
  padding: 0.7rem 1.5rem;
  line-height: 1;
}
.btn-amber { background: var(--amber); color: #ffffff; }
.btn-amber:hover { background: #6aaee8; }
.btn-ghost { background: transparent; color: var(--white); border: 1.5px solid var(--border-lt); }
.btn-ghost:hover { border-color: var(--amber); color: var(--amber); }
.btn-white { background: var(--white); color: var(--bg); }
.btn-white:hover { background: var(--off-white); }
.btn-lg { padding: 0.95rem 2rem; font-size: 0.97rem; }

/* HERO */
.hero {
  background: var(--bg);
  padding: 7rem 2rem 6rem;
  border-bottom: 1px solid var(--border);
  position: relative;
  overflow: hidden;
}
.hero::after {
  content: '';
  position: absolute;
  top: 0; right: 0;
  width: 45%;
  height: 100%;
  background: linear-gradient(135deg, transparent 40%, rgba(46,109,164,0.06) 100%);
  pointer-events: none;
}
.hero-inner { max-width: 900px; position: relative; z-index: 1; }
.hero h1 { color: var(--white); margin-bottom: 1.5rem; max-width: 820px; }
.hero h1 span { color: var(--amber); }
.hero-sub { font-size: 1.1rem; color: var(--muted); max-width: 600px; margin-bottom: 1rem; line-height: 1.72; }
.hero-fee {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.1rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--amber);
  margin-bottom: 2.5rem;
  line-height: 1.7;
}
.hero-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }

/* STAT BAR */
.stat-bar {
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
}
.stat-bar-inner {
  max-width: 1160px; margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
}
.stat-item {
  padding: 1.75rem 1.5rem;
  border-right: 1px solid var(--border);
  text-align: center;
}
.stat-item:last-child { border-right: none; }
.stat-num {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 2rem;
  color: var(--white);
  display: block;
  line-height: 1;
  margin-bottom: 0.3rem;
  letter-spacing: 0.02em;
}
.stat-lbl {
  font-size: 0.82rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
}

/* TWO-COL INTRO */
.intro-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: start;
}
.intro-body { font-size: 1.1rem; color: var(--muted); line-height: 1.75; }
.intro-body p + p { margin-top: 1rem; }
.intro-body strong { color: var(--off-white); }

.quote-block {
  border-left: 3px solid var(--amber);
  padding: 0 0 0 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1.1rem;
}
.quote-line {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--off-white);
  text-transform: uppercase;
  letter-spacing: 0.04em;
  line-height: 1.35;
}

/* CALLOUTS */
.callout {
  border-radius: 0;
  padding: 1.25rem 1.5rem;
  margin-top: 1.25rem;
}
.callout-warn {
  background: var(--red-dim);
  border: 1px solid rgba(180,40,40,0.3);
  border-left: 3px solid var(--red-rule);
}
.callout-warn h4 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.97rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #e06060;
  margin-bottom: 0.4rem;
}
.callout-warn p { font-size: 0.97rem; color: #c08080; }
.callout-teal {
  background: var(--teal-dim);
  border: 1px solid rgba(26,138,122,0.3);
  border-left: 3px solid var(--teal-rule);
}
.callout-teal h4 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.97rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #4ac4b0;
  margin-bottom: 0.4rem;
}
.callout-teal p { font-size: 0.97rem; color: #7ab8b0; }

/* PROCESS */
.process-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  margin-top: 3rem;
  border: 1px solid var(--border);
}
.process-step {
  padding: 2rem 1.5rem;
  border-right: 1px solid var(--border);
  position: relative;
}
.process-step:last-child { border-right: none; }
.process-step:nth-child(even) { background: var(--bg2); }
.pn {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 3.5rem;
  color: var(--border-lt);
  line-height: 1;
  margin-bottom: 1rem;
  display: block;
}
.process-step h3 {
  font-size: 1.1rem;
  color: var(--white);
  margin-bottom: 0.6rem;
  letter-spacing: 0.08em;
}
.process-step p { font-size: 1.1rem; line-height: 1.65; }

/* BENEFITS */
.benefits-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
  margin-top: 3rem;
}
.benefit-item {
  background: var(--bg2);
  padding: 2rem 1.75rem;
}
.benefit-bar {
  width: 32px; height: 3px;
  background: #1e3a5f;
  margin-bottom: 1.1rem;
}
.benefit-item h3 { font-size: 1.1rem; color: var(--white); margin-bottom: 0.6rem; letter-spacing: 0.06em; }
.benefit-item p { font-size: 0.97rem; }

/* WHO WE SERVE */
.serve-list { list-style: none; margin-top: 1.75rem; display: flex; flex-direction: column; gap: 0.6rem; }
.serve-list li {
  padding: 1rem 1.25rem 1rem 3rem;
  background: var(--bg2);
  border: 1px solid var(--border);
  font-size: 1.1rem;
  color: var(--muted);
  position: relative;
  line-height: 1.55;
}
.serve-list li::before {
  content: '→';
  position: absolute;
  left: 1.1rem;
  color: var(--amber);
  font-weight: 700;
  font-size: 1.1rem;
}

/* SERVICES */
.svc-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 0.5rem;
  margin-top: 2rem;
}
.svc-item {
  display: flex; gap: 0.75rem; align-items: flex-start;
  padding: 0.9rem 1rem;
  background: var(--bg2);
  border: 1px solid var(--border);
  font-size: 0.97rem;
  color: var(--muted);
}
.svc-item::before { content: '✓'; color: var(--amber); font-weight: 700; flex-shrink: 0; margin-top: 1px; }

/* CASE STUDIES */
.cases-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
  margin-top: 2.5rem;
}
.case-card { background: var(--bg2); }
.case-head {
  background: var(--bg3);
  border-bottom: 1px solid var(--border);
  padding: 1rem 1.4rem;
}
.case-head h3 {
  font-size: 1.1rem;
  color: var(--amber);
  letter-spacing: 0.12em;
}
.case-body { padding: 1.25rem 1.4rem; }
.case-row { display: flex; gap: 0.75rem; margin-bottom: 0.7rem; font-size: 0.97rem; }
.case-row:last-child { margin-bottom: 0; }
.cl { font-weight: 700; color: var(--white); min-width: 75px; flex-shrink: 0; font-size: 1.1rem; text-transform: uppercase; letter-spacing: 0.06em; }
.cv { color: var(--muted); line-height: 1.5; }

/* FAQ */
.faq-list { margin-top: 2.5rem; display: flex; flex-direction: column; }
.faq-item { border-bottom: 1px solid var(--border); }
.faq-item:first-child { border-top: 1px solid var(--border); }
.faq-q {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.1rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--off-white);
  padding: 1.1rem 0;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  user-select: none;
  transition: color 0.15s;
}
.faq-q:hover { color: var(--amber); }
.faq-q::after { content: '+'; font-size: 1.2rem; color: var(--amber); flex-shrink: 0; font-weight: 300; font-family: 'Barlow', sans-serif; }
.faq-item.open .faq-q { color: var(--amber); }
.faq-item.open .faq-q::after { content: '−'; }
.faq-a { font-size: 0.97rem; color: var(--muted); line-height: 1.7; padding-bottom: 1.1rem; display: none; }
.faq-item.open .faq-a { display: block; }

/* PROOF ROW */
.proof-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border: 1px solid var(--border);
  margin-top: 2.5rem;
}
.proof-item {
  padding: 1.75rem 1.25rem;
  border-right: 1px solid var(--border);
  text-align: center;
}
.proof-item:last-child { border-right: none; }
.proof-num {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 2rem;
  color: var(--amber);
  display: block;
  margin-bottom: 0.3rem;
  line-height: 1;
}
.proof-desc { font-size: 0.82rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }

/* CONTACT */
.contact-section { background: var(--bg2); border-top: 1px solid var(--border); padding: 5rem 2rem; }
.contact-grid {
  max-width: 1160px; margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1.05fr;
  gap: 5rem;
  align-items: start;
}
.contact-left h2 { color: var(--white); margin-bottom: 1rem; }
.contact-lead { font-size: 1.1rem; line-height: 1.75; margin-bottom: 1.5rem; }
.contact-fee {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.1rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--amber);
  margin-bottom: 2rem;
  line-height: 1.7;
}

.cib { background: var(--bg3); border: 1px solid var(--border); padding: 1.1rem 1.25rem; margin-bottom: 0.6rem; }
.cib-lbl { font-size: 0.78rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.3rem; }
.cib-val { font-size: 1.1rem; color: var(--off-white); font-weight: 500; }
.cib-val a { color: var(--amber-lt); text-decoration: none; }
.cib-val a:hover { text-decoration: underline; }

/* FORM */
.form-card { background: var(--bg3); border: 1px solid var(--border); padding: 2.25rem; }
.form-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.6rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: var(--white);
  margin-bottom: 0.3rem;
}
.form-sub {
  font-size: 0.82rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  color: var(--muted);
  margin-bottom: 1.5rem;
  padding-bottom: 1.25rem;
  border-bottom: 1px solid var(--border);
  line-height: 1.6;
}
.form-group { margin-bottom: 1rem; }
.form-group label {
  display: block;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 0.4rem;
}
.req { color: var(--amber); }
.form-group input {
  width: 100%;
  padding: 0.75rem 0.9rem;
  background: var(--bg);
  border: 1px solid var(--border);
  color: var(--white);
  font-family: 'Barlow', sans-serif;
  font-size: 1.1rem;
  border-radius: 0;
  transition: border-color 0.15s;
}
.form-group input:focus { outline: none; border-color: var(--amber); }
.form-group input::placeholder { color: var(--border-lt); }
.field-error { font-size: 0.84rem; color: #e06060; margin-top: 0.3rem; display: none; font-weight: 600; }
.field-error.show { display: block; }

.consent-row { display: flex; gap: 0.75rem; align-items: flex-start; margin-bottom: 1.25rem; }
.consent-row input[type="checkbox"] { margin-top: 3px; flex-shrink: 0; accent-color: var(--amber); width: 15px; height: 15px; }
.consent-row label { font-size: 1.1rem; color: var(--muted); line-height: 1.55; cursor: pointer; }

.btn-submit {
  width: 100%;
  padding: 1rem;
  background: #1e3a5f;
  color: #e8eef6;
  border: none;
  border-radius: 0;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.97rem;
  font-weight: 800;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.15s;
}
.btn-submit:hover { background: #6aaee8; }
.btn-submit:disabled { opacity: 0.5; cursor: not-allowed; }
.form-note { font-size: 0.82rem; color: var(--muted); text-align: center; margin-top: 0.75rem; line-height: 1.55; }

.form-success {
  display: none;
  padding: 2rem;
  text-align: center;
  background: var(--green-dim);
  border: 1px solid rgba(26,122,74,0.35);
}
.form-success .s-icon { font-size: 1.8rem; margin-bottom: 0.75rem; display: block; }
.form-success h3 {
  font-size: 1.3rem;
  color: #4ac880;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin-bottom: 0.6rem;
}
.form-success p { font-size: 0.97rem; color: #7ab898; line-height: 1.7; margin-bottom: 0.4rem; }
.form-success p:last-child { margin-bottom: 0; }

.mn-reject {
  background: var(--red-dim);
  border: 1px solid rgba(180,40,40,0.4);
  border-left: 3px solid var(--red-rule);
  padding: 0.75rem 1rem;
  font-size: 1.1rem;
  color: #e06060;
  font-weight: 600;
  margin-bottom: 0.75rem;
  display: none;
}

/* FINAL CTA */
.final-cta {
  background: var(--bg);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: 6rem 2rem;
  text-align: center;
}
.final-cta h2 { color: var(--white); max-width: 740px; margin: 0 auto 1rem; }
.final-cta p { max-width: 500px; margin: 0 auto 0.5rem; font-size: 1.1rem; line-height: 1.7; }
.final-fee {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.1rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--amber);
  margin-bottom: 2.5rem;
  margin-top: 0.5rem;
}
.final-btns { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }

/* FOOTER */
footer {
  background: var(--bg2);
  border-top: 1px solid var(--border);
  padding: 2.5rem 2rem;
}
.footer-inner {
  max-width: 1160px; margin: 0 auto;
  display: flex; justify-content: space-between; align-items: flex-start;
  flex-wrap: wrap; gap: 1.5rem;
  font-size: 1.1rem; color: var(--muted); line-height: 1.8;
}
.footer-brand {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 1.1rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--white);
  display: block;
  margin-bottom: 0.3rem;
}
.footer-links { display: flex; gap: 1.5rem; flex-wrap: wrap; }
.footer-links a { color: var(--muted); text-decoration: none; transition: color 0.15s; }
.footer-links a:hover { color: var(--amber); }
.footer-right { text-align: right; }

/* RESPONSIVE */
@media (max-width: 960px) {
  .intro-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  .contact-grid { grid-template-columns: 1fr; gap: 3rem; }
  .process-grid { grid-template-columns: 1fr 1fr; }
  .cases-grid { grid-template-columns: 1fr; gap: 1px; }
  .proof-row { grid-template-columns: 1fr 1fr; }
  .proof-item:nth-child(2) { border-right: none; }
  .proof-item:nth-child(3) { border-top: 1px solid var(--border); }
  .proof-item:nth-child(4) { border-top: 1px solid var(--border); border-right: none; }
  .benefits-grid { grid-template-columns: 1fr; }
  .footer-inner { flex-direction: column; }
  .footer-right { text-align: left; }
}
@media (max-width: 640px) {
  section { padding: 3.5rem 1.25rem; }
  .site-header { padding: 0 1.25rem; }
  .hero { padding: 4rem 1.25rem; }
  .process-grid { grid-template-columns: 1fr; }
  .stat-bar-inner { grid-template-columns: 1fr 1fr; }
  .stat-item:nth-child(odd) { border-right: 1px solid var(--border); }
  .stat-item { border-bottom: 1px solid var(--border); }
  .stat-item:last-child { border-bottom: none; }
  .form-card { padding: 1.5rem; }
  .contact-section { padding: 3.5rem 1.25rem; }
  .header-inner { height: auto; padding: 0.75rem 0; flex-wrap: wrap; }
  .proof-row { grid-template-columns: 1fr 1fr; }
}
</style>
</head>
<body>



<!-- HEADER -->
<header class="site-header">
  <div class="header-inner">
    <a href="#" class="logo">
      Pillars ALF Partners

    </a>
    <div class="nav-actions">
      <a href="tel:7633637550" class="btn btn-ghost">(763) 363-7550</a>
      <a href="#intake-form" class="btn btn-amber">Confidential Intake</a>
    </div>
  </div>
</header>

<!-- HERO -->
<section class="hero">
