<script>
document.querySelectorAll('.faq-q').forEach(q => {
  q.addEventListener('click', () => {
    const item = q.parentElement;
    const wasOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
    if (!wasOpen) item.classList.add('open');
  });
});

function showErr(id, show) {
  const el = document.getElementById(id);
  if (el) el.classList.toggle('show', show);
}

document.getElementById('intake-form-el').addEventListener('submit', async function(e) {
  e.preventDefault();
  let valid = true;

  const name = document.getElementById('f-name').value.trim();
  showErr('err-name', !name); if (!name) valid = false;

  const phone = document.getElementById('f-phone').value.trim();
  showErr('err-phone', !phone); if (!phone) valid = false;

  const company = document.getElementById('f-company').value.trim();
  showErr('err-company', !company); if (!company) valid = false;

  const consent = document.getElementById('f-consent').checked;
  showErr('err-consent', !consent); if (!consent) valid = false;

  if (!valid) return;

  const btn = document.querySelector('.btn-submit');
  btn.textContent = 'Submitting...';
  btn.disabled = true;

  try {
    const response = await fetch('https://formspree.io/f/mqeogjne', {
      method: 'POST',
      body: new FormData(this),
      headers: { 'Accept': 'application/json' }
    });
    if (response.ok) {
      this.style.display = 'none';
      document.getElementById('mn-reject').style.display = 'none';
      const s = document.getElementById('form-success');
      s.style.display = 'block';
      s.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } else {
      btn.textContent = 'Submit Confidential Intake';
      btn.disabled = false;
      alert('Something went wrong. Please call us at (763) 363-7550.');
    }
  } catch(err) {
    btn.textContent = 'Submit Confidential Intake';
    btn.disabled = false;
    alert('Something went wrong. Please call us at (763) 363-7550.');
  }
});
</script>
